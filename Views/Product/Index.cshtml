@model List<InventoryManagementSystem.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Inventory Products</h2>
        <a href="/Product/Create" class="btn btn-primary">+ Add New Product</a>
    </div>

    <!-- Low stock alert -->
    @if (Model.Any(p => p.IsLowStock))
    {
        <div class="alert alert-warning">
            ⚠️ <strong>@Model.Count(p => p.IsLowStock) products</strong> 
            are below minimum stock level!
        </div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Supplier</th>
                <th>Quantity</th>
                <th>Min Level</th>
                <th>Unit Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr class="@(product.IsLowStock ? "table-danger" : "")">
                    <td>@product.ProductId</td>
                    <td>@product.Name</td>
                    <td>@product.CategoryName</td>
                    <td>@product.SupplierName</td>
                    <td>
                        <strong>@product.Quantity</strong>
                    </td>
                    <td>@product.MinStockLevel</td>
                    <td>₹@product.UnitPrice.ToString("N2")</td>
                    <td>
                        @if (product.IsLowStock)
                        {
                            <span class="badge bg-danger">Low Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-success">In Stock</span>
                        }
                    </td>
                    <td>
                        <a href="/Product/AddStock/@product.ProductId"
                           class="btn btn-success btn-sm">+ Stock</a>
                        <a href="/Product/Delete/@product.ProductId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this product?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>